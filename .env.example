SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite:///instance/sirentracker.db

# Google Workspace OAuth (for admin login)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_WORKSPACE_DOMAIN=yourdomain.org

# Gmail API sender address (token is in instance/gmail_token.json)
GMAIL_SENDER=SirenTracker <alerts@yourdomain.org>
